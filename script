-- ======== ЛОГИКА AUTO GENERATOR ========
local autoGenThread = nil
local function FindNearestGenerator()
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local map = workspace:FindFirstChild("Map"):FindFirstChild("Ingame"):FindFirstChild("Map")
    if not map then return nil end
    local nearestGen = nil
    local nearestDist = math.huge
    for _, gen in ipairs(map:GetChildren()) do
        if gen:IsA("Model") and gen.Name == "Generator" and gen:FindFirstChild("Main") and gen:FindFirstChild("Remotes") then
            -- Проверка, что генератор не завершён (если есть Progress)
            local progress = gen:FindFirstChild("Progress")
            if progress and progress:IsA("NumberValue") and progress.Value >= 100 then
                continue
            end
            local main = gen.Main
            local dist = (main.Position - root.Position).Magnitude
            if dist < 6.5 and dist < nearestDist then
                nearestDist = dist
                nearestGen = gen
            end
        end
    end
    return nearestGen
end

Toggles.AutoSolve:OnChanged(function(value)
    if value then
        if autoGenThread then return end
        autoGenThread = task.spawn(function()
            while Toggles.AutoSolve.Value do
                task.wait(0.5)
                pcall(function()
                    local gen = FindNearestGenerator()
                    if not gen then
                        -- Обновим статус
                        return
                    end
                    local remotes = gen.Remotes
                    local RF = remotes:FindFirstChild("RF")
                    local RE = remotes:FindFirstChild("RE")
                    if not RF or not RE then return end

                    -- Вход в генератор
                    RF:InvokeServer("enter")

                    local stepsDone = 0
                    while stepsDone < 4 and Toggles.AutoSolve.Value do
                        local cooldown = Options.AutoGenCooldown.Value
                        if cooldown < 1.5 then
                            -- Быстрая стратегия с выходом/входом
                            RE:FireServer()
                            stepsDone = stepsDone + 1
                            task.wait(0.15)
                            RF:InvokeServer("leave")
                            task.wait(0.3)
                            if stepsDone < 4 then
                                RF:InvokeServer("enter")
                                task.wait(0.1)
                            end
                        else
                            task.wait(cooldown)
                            if not Toggles.AutoSolve.Value then break end
                            RE:FireServer()
                            stepsDone = stepsDone + 1
                        end
                    end
                    -- Выход, если ещё не вышли
                    if (Options.AutoGenCooldown.Value >= 1.5) or (stepsDone == 4) then
                        pcall(function() RF:InvokeServer("leave") end)
                    end
                end)
            end
        end)
    else
        if autoGenThread then
            task.cancel(autoGenThread)
            autoGenThread = nil
        end
    end
end)

