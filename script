function indexGenerators()
    table.clear(IndexedGenerators)
    local ingame = workspace:FindFirstChild("Map") 
        and workspace.Map:FindFirstChild("Ingame") 
        and workspace.Map.Ingame:FindFirstChild("Map")
        
    if ingame then
        for _, obj in ipairs(ingame:GetChildren()) do
            if obj.Name:lower():find("generator") and obj:FindFirstChild("Remotes") then
                local rf = obj.Remotes:FindFirstChild("RF")
                local re = obj.Remotes:FindFirstChild("RE")
                local rootPart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                
                if rf and re and rootPart then
                    table.insert(IndexedGenerators, {
                        Object = obj,
                        Position = rootPart.Position,
                        RF = rf,
                        RE = re
                    })
                end
            end
        end
    end
end

