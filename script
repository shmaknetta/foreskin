local espFolder = Instance.new("Folder", game.CoreGui)
espFolder.Name = "ESPFolder"
local function updateESP()
    espFolder:ClearAllChildren()
    for _, espData in ipairs(espTypes) do
        local toggle = Toggles[espData[1] .. "ESP"]
        if toggle and toggle.Value then
            local color = Options[espData[1] .. "Color"] and Options[espData[1] .. "Color"].Value or Color3.new(1,1,1)
            local targets = {}
            if espData[1] == "Player" then
                for _, plr in ipairs(game.Players:GetPlayers()) do
                    if plr ~= game.Players.LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                        table.insert(targets, plr.Character)
                    end
                end
            elseif espData[1] == "Generators" then
                local map = workspace:FindFirstChild("Map"):FindFirstChild("Ingame"):FindFirstChild("Map")
                if map then
                    for _, gen in ipairs(map:GetChildren()) do
                        if gen:IsA("Model") and gen.Name == "Generator" and gen:FindFirstChild("Main") then
                            table.insert(targets, gen)
                        end
                    end
                end
            elseif espData[1] == "Items" then
                -- можно добавить поиск предметов
            end
            for _, obj in ipairs(targets) do
                local highlight = Instance.new("Highlight")
                highlight.Adornee = obj
                highlight.FillColor = color
                highlight.OutlineColor = color
                highlight.Parent = espFolder
            end
        end
    end
end
for _, espData in ipairs(espTypes) do
    Toggles[espData[1] .. "ESP"]:OnChanged(updateESP)
end

