SpeedTab:AddToggle("PositionSync", {
    Text = "CFrame Speed Override",
    Default = false,
})
Toggles.PositionSync:OnChanged(function(value)
    if value then
        if posSyncConnection then return end
        posSyncConnection = game:GetService("RunService").Heartbeat:Connect(function(dt)
            if not Toggles.PositionSync.Value then return end
            local char = game.Players.LocalPlayer.Character
            if not char then return end
            local hum = char:FindFirstChildWhichIsA("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if root and hum and hum.MoveDirection.Magnitude > 0 then
                local moveDir = hum.MoveDirection
                local speedDiff = targetSpeed - hum.WalkSpeed
                if speedDiff > 0 then
                    root.CFrame = root.CFrame + moveDir * speedDiff * dt
                end
            end
        end)
    else
        if posSyncConnection then
            posSyncConnection:Disconnect()
            posSyncConnection = nil
        end
    end
end)

-- Stamina Tab
StaminaTab:AddToggle("SmartEndurance", {
    Text = "Smart Endurance Sync",
    Default = false,
})
local enduranceSyncActive = false
local enduranceSyncThread = nil
Toggles.SmartEndurance:OnChanged(function(value)
    if value then
        if enduranceSyncActive then return end
        enduranceSyncActive = true
        enduranceSyncThread = task.spawn(function()
            while enduranceSyncActive do
                task.wait(0.5)
                pcall(function()
                    local char = game.Players.LocalPlayer.Character
                    if not char then return end
                    local currentStamina = nil
                    if staminaModule and type(staminaModule.Stamina) == "number" then
                        currentStamina = staminaModule.Stamina
                    else
                        local hum = char:FindFirstChildWhichIsA("Humanoid")
                        if hum then currentStamina = hum:GetAttribute("Stamina") end
                    end
                    if type(currentStamina) == "number" and currentStamina < 15 then
                        if staminaModule then
                            staminaModule.Stamina = 100
                        else
                            local hum = char:FindFirstChildWhichIsA("Humanoid")
                            if hum then hum:SetAttribute("Stamina", 100) end
                        end
                    end
                end)
            end
        end)
    else
        enduranceSyncActive = false
        if enduranceSyncThread then
            task.cancel(enduranceSyncThread)
            enduranceSyncThread = nil
        end
    end
end)

