local GenGroup = Tabs.Generators:AddLeftGroupbox('Автоматизация Новых Генераторов')

GenGroup:AddToggle('AutoSolveNewGen', {
    Text = 'Авто-починка генераторов',
    Default = false,
    Tooltip = 'Чинит любой генератор из кэша памяти без лагов процессора',
    Callback = function(Value)
        _G.NewGenFarmActive = Value
        if Value then
            indexGenerators()
            task.spawn(function()
                while _G.NewGenFarmActive do
                    task.wait(0.4)
                    local char = LocalPlayer.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    
                    if root then
                        local myPos = root.Position
                        local radius = Options.NewGenRadiusSlider.Value
                        
                        for _, gen in ipairs(IndexedGenerators) do
                            if not _G.NewGenFarmActive then break end
                            local distance = (gen.Position - myPos).Magnitude
                            if distance <= radius then
                                pcall(function()
                                    gen.RF:InvokeServer("enter")
                                    task.wait(0.05)
                                    for i = 1, 7 do
                                        if not _G.NewGenFarmActive then break end
                                        gen.RE:FireServer()
                                        task.wait(0.02)
                                    end
                                end)
                                task.wait(0.5)
                            end
                        end
                    end
                end
            end)
        end
    end
})

